  "alarms": {
    "philosophy": "Aligned to KiSTI-20 HMI alarm suppression per SI-Drive mode",
    "severity_levels": {
      "CRITICAL": {"intelligent": "FIRE", "sport": "FIRE", "sport_sharp": "FIRE + FULL SCREEN RED OVERLAY"},
      "ADVISORY": {"intelligent": "FIRE", "sport": "FIRE", "sport_sharp": "SUPPRESSED"},
      "INFO": {"intelligent": "FIRE", "sport": "SUPPRESSED", "sport_sharp": "SUPPRESSED"}
    },
    "conditions": [
      {"name": "Low Oil Pressure", "severity": "CRITICAL", "channel": "OIL_PRESS", "condition": "< 100 kPa when RPM > 1000"},
      {"name": "High Coolant Temp", "severity": "CRITICAL", "channel": "ECT", "condition": "> 110 degC"},
      {"name": "Low Fuel Pressure", "severity": "CRITICAL", "channel": "FUEL_PRESS", "condition": "< min threshold (tune-dependent)"},
      {"name": "High Knock", "severity": "CRITICAL", "channel": "KNOCK_LEV1-4", "condition": "> threshold (tune-dependent)"},
      {"name": "Trigger Errors", "severity": "CRITICAL", "channel": "TRIG1_ERR", "condition": "> 10 in rolling window"},
      {"name": "Low Battery", "severity": "ADVISORY", "channel": "VOLTS", "condition": "< 12.0 V"},
      {"name": "High Coolant Early", "severity": "ADVISORY", "channel": "ECT", "condition": "> 100 degC"},
      {"name": "High IAT", "severity": "ADVISORY", "channel": "IAT", "condition": "> 50 degC"},
      {"name": "High Inj Duty", "severity": "ADVISORY", "channel": "INJ_DC", "condition": "> 85%"},
      {"name": "Oil Temp High", "severity": "INFO", "channel": "OILT", "condition": "> 130 degC"},
      {"name": "Oil Temp Low", "severity": "INFO", "channel": "OILT", "condition": "< 70 degC"},
      {"name": "Fault Code Present", "severity": "INFO", "channel": "FAULT_CODE", "condition": "> 0"}
    ]
  },

