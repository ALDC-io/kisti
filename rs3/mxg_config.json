  "can_bus": {
    "can1": {
      "status": "COMMITTED",
      "protocol": "LINK / CAN_BUS_BASE_LCC",
      "description": "Built-in AiM MXS Strada dedicated stream",
      "bit_rate_mbps": 1,
      "base_can_id": 1000,
      "can_id_hex": "0x3E8",
      "format": "Normal_11bit",
      "transmit_rate_hz": 50,
      "total_channels": 42,
      "dbc_file": "CAN1_Link_AiM_MXS_Strada.dbc",
      "pclink_mode": "Transmit Link AiM MXS Strada dash",
      "firmware_requirement": "G4+ 5.6.6+ / G4X any / G5 Neo any"
    },
    "can2": {
      "status": "RESERVED — NOT COMMITTED",
      "description": "Available for KiSTI-specific CAN frames if design requires",
      "bit_rate_mbps": 1,
      "dbc_file": "CAN2_KiSTI_Custom_Frames.dbc",
      "candidates": {
        "likely": [
          {
            "name": "SI-Drive State",
            "can_id_hex": "0x6B0",
            "can_id_dec": 1712,
            "rate_hz": 10,
            "signals": ["SI_Drive_Mode", "SI_Drive_Transition", "Warmup_Complete"],
            "rationale": "Enables mode-aware display page switching on MXG"
          }
        ],
        "possible": [
          {
            "name": "DCCD Torque Split",
            "can_id_hex": "0x6A0",
            "can_id_dec": 1712,
            "rate_hz": 50,
            "signals": ["DCCD_Front_Torque", "DCCD_Rear_Torque", "DCCD_Mode", "DCCD_Lock_Pct"],
            "rationale": "Sport page could show torque split visualization"
          },
          {
            "name": "Context Frame",
            "can_id_hex": "0x6A1",
            "can_id_dec": 1713,
            "rate_hz": 10,
            "signals": ["Drive_Context", "Surface_Type", "Confidence", "AI_Alert_Level"],
            "rationale": "Enriches Intelligent page with AI context"
          },
          {
            "name": "Dynamics",
            "can_id_hex": "0x6A3",
            "can_id_dec": 1715,
            "rate_hz": 50,
            "signals": ["Yaw_Rate", "Lateral_G", "Longitudinal_G", "Slip_Angle"],
            "rationale": "Sport# track data — G-force and slip"
          },
          {
            "name": "IMU Accel/Gyro",
            "can_id_hex": "0x6A6",
            "can_id_dec": 1718,
            "rate_hz": 50,
            "signals": ["Accel_X", "Accel_Y", "Gyro_Z"],
            "rationale": "Track analysis data"
          }
        ],
        "unlikely": [
          {"name": "Wheel Speed Detail", "can_id_hex": "0x6A2", "rationale": "CAN1 SPEED1-4 covers this"},
          {"name": "GPS Position", "can_id_hex": "0x6A4", "rationale": "MXG has own GPS module"},
          {"name": "GPS Velocity", "can_id_hex": "0x6A5", "rationale": "MXG GPS covers this"},
          {"name": "IMU Orientation", "can_id_hex": "0x6A7", "rationale": "Niche use on dash display"},
          {"name": "Keypad", "can_id_hex": "0x6B2", "rationale": "No softkeys on MXG"}
        ],
        "deferred": [
          {"name": "Extended Sensors", "can_id_hex": "0x6B1", "rationale": "Content TBD"}
        ]
      }
    }
  },

  "display": {
    "architecture": "3 screens, 1 per SI-Drive mode. No sub-pages, no softkeys.",
    "resolution": "800x480",
    "pages": {
      "intelligent": {
        "index": 0,
        "si_drive_value": 0,
        "accent_color": "#00AAFF",
        "accent_name": "Blue",
        "philosophy": "Calm, diagnostic, all-systems-healthy view",
        "data_density": "Medium — 6-8 readouts",
        "layout": {
          "hero_top_center": {"channel": "RPM", "widget": "bar_graph", "secondary": "GEAR"},
          "left_primary": {"channel": "ECT", "widget": "gauge", "label": "Coolant"},
          "right_primary": {"channel": "OIL_PRESS", "widget": "gauge", "label": "Oil Press"},
          "lower_left": {"channel": "SPEED1", "widget": "numeric", "label": "Speed"},
          "lower_right": {"channels": ["FUEL_PRESS", "VOLTS"], "widget": "dual_numeric"},
          "status_strip": {"channels": ["ECT", "IAT", "VOLTS", "FUEL_PRESS"], "widget": "text_strip"}
        },
        "alerts": {
          "critical": "ALWAYS FIRE",
          "advisory": "FIRE",
          "info": "FIRE"
        }
      },
      "sport": {
        "index": 1,
        "si_drive_value": 1,
        "accent_color": "#FF8800",
        "accent_name": "Amber",
        "philosophy": "Performance dashboard, data-rich",
        "data_density": "High — 8-12 readouts",
        "layout": {
          "hero_top_center": {"channel": "RPM", "widget": "bar_graph", "secondary": "GEAR"},
          "left_primary": {"channels": ["MAP", "MGP"], "widget": "boost_gauge", "label": "Boost"},
          "right_primary": {"channels": ["OIL_PRESS", "OILT"], "widget": "combo_gauge", "label": "Oil"},
          "lower_left": {"channels": ["WBO2_LAM1", "WBO2_LAM2"], "widget": "afr_gauge", "label": "AFR"},
          "lower_right": {"channels": ["IGN_TIM", "KNOCK_LEV1", "KNOCK_LEV2", "KNOCK_LEV3", "KNOCK_LEV4"], "widget": "knock_summary", "label": "Timing/Knock"},
          "status_strip": {"channels": ["ECT", "IAT", "VOLTS", "INJ_DC"], "widget": "text_strip"}
        },
        "alerts": {
          "critical": "ALWAYS FIRE",
          "advisory": "FIRE",
          "info": "SUPPRESSED"
        }
      },
      "sport_sharp": {
        "index": 2,
        "si_drive_value": 2,
        "accent_color": "#FF0000",
        "accent_name": "Red",
        "philosophy": "Track attack, minimal, big numbers only",
        "data_density": "Low — 4-5 max, large fonts",
        "layout": {
          "hero_top_center": {"channel": "RPM", "widget": "large_numeric", "secondary": "GEAR", "gear_size": "XL"},
          "left_primary": {"channel": "MAP", "widget": "horizontal_bar", "label": "Boost"},
          "right_primary": {"channel": "SPEED1", "widget": "large_numeric", "label": "Speed"},
          "lower_left": {"channel": "TPS", "widget": "horizontal_bar", "label": "Throttle"},
          "lower_right": {"channel": "INJ_DC", "widget": "warning_zone", "label": "Inj Duty", "warning_threshold": 85},
          "status_strip": {"channels": ["ECT", "OIL_PRESS", "VOLTS"], "widget": "text_strip_minimal"}
        },
        "alerts": {
          "critical": "ALWAYS FIRE + FULL SCREEN RED OVERLAY",
          "advisory": "SUPPRESSED",
          "info": "SUPPRESSED"
        }
      }
    }
  },

