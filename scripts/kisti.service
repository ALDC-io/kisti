[Unit]
Description=KiSTI - Edge AI Co-Driver
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=aldc
Group=aldc
WorkingDirectory=/home/aldc/repos/kisti
Environment="DISPLAY=:0"
Environment="QT_QPA_PLATFORM=eglfs"
Environment="OLLAMA_MODELS=/data/ollama"
ExecStart=/usr/bin/python3 main.py --fullscreen
Restart=on-failure
RestartSec=5
StartLimitBurst=3
StartLimitIntervalSec=300

[Install]
WantedBy=multi-user.target
