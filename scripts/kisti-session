#!/bin/bash
# KiSTI minimal X session — replaces GNOME desktop to free GPU memory
#
# GDM handles login; this script IS the entire desktop session.
# No window manager, no compositor, no desktop — just KiSTI fullscreen.
# Frees ~500MB unified memory for Ollama CUDA inference.
#
# Install: sudo cp scripts/kisti-session.desktop /usr/share/xsessions/
#          sudo cp scripts/kisti-session /usr/local/bin/ && sudo chmod +x /usr/local/bin/kisti-session
# Select "KiSTI" session from GDM gear icon at login.

set -e

# Use XDG_RUNTIME_DIR for lock (survives /tmp clears, per-user, race-safe)
LOCKFILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/kisti-session.lock"

# Singleton: flock is atomic — if another instance holds the lock, exit immediately.
exec 9>"$LOCKFILE"
if ! flock -n 9; then
    echo "$(date) duplicate session blocked by flock, exiting" >> /tmp/kisti-session.log
    exit 0
fi
# Lock held for lifetime of this process (fd 9 stays open).

export DISPLAY="${DISPLAY:-:0}"
export QT_QPA_PLATFORM=xcb
export OLLAMA_MODELS=/data/ollama
# PULSE_SERVER not set — let PA use its default socket path
export LD_LIBRARY_PATH="/usr/local/cuda/lib64:$HOME/.local/lib:${LD_LIBRARY_PATH:-}"

KISTI_DIR="$HOME/repos/kisti"
LOG="/tmp/kisti-session.log"

# Kill any orphaned KiSTI from a previous crash
pkill -9 -f 'python3 main.py' 2>/dev/null || true
sleep 1

echo "$(date) KiSTI session starting (PID $$)" > "$LOG"

# Black background, no screen blanking
xsetroot -solid black 2>/dev/null || true
xset s off -dpms 2>/dev/null || true

# PulseAudio must stay running: Jetson HDA codec resets pin-ctl to 0x00
# when PA exits, killing HDMI audio. Keep PA alive for the session lifetime.
pulseaudio --kill 2>/dev/null || true
systemctl --user stop pulseaudio.socket pulseaudio.service 2>/dev/null || true
sleep 0.5
pulseaudio --start --exit-idle-time=-1 2>/dev/null || true
sleep 2
# Audio output: prefer USB speaker, fall back to HDMI
USB_SINK=$(pactl list sinks short 2>/dev/null | grep -i 'usb.*Jieli\|usb.*speaker\|usb.*audio' | head -1 | awk '{print $2}')
if [ -n "$USB_SINK" ]; then
    pactl set-default-sink "$USB_SINK" 2>/dev/null || true
    pactl set-sink-volume "$USB_SINK" 78% 2>/dev/null || true
    echo "$(date) USB speaker default: $USB_SINK @ 78%" >> "$LOG"
else
    pactl set-default-sink alsa_output.platform-3510000.hda.HiFi__hw_HDA_3__sink 2>/dev/null || true
    echo "$(date) No USB speaker — HDMI sink default" >> "$LOG"
fi

# Stop Ollama — persona-first handles 90% of queries, free GPU for Whisper STT
sudo -n systemctl stop ollama 2>/dev/null || true
echo "$(date) Ollama stopped (persona-first mode)" >> "$LOG"

# Bring up CAN if adapter connected
sudo -n ip link set can0 up type can bitrate 1000000 2>/dev/null || true

# LLM pre-load skipped — persona-first mode, Ollama stopped for GPU headroom

# Launch KiSTI fullscreen — when it exits, session ends → back to GDM
echo "$(date) Launching KiSTI" >> "$LOG"
cd "$KISTI_DIR"
# Detect USB mic via PulseAudio source (PA holds the ALSA device)
MIC_CARD=$(arecord -l 2>/dev/null | grep -i 'USB.*MIC\|USB.*Audio\|USB.*Adapter' | head -1 | grep -oP 'card \K\d+' || true)
if [ -n "$MIC_CARD" ]; then
    # ALSA 100% + PA 200% = clean speech/noise separation for Silero VAD
    # 500% drowns VAD in amplified noise; 150% too quiet; 200% is the sweet spot
    amixer -c "$MIC_CARD" cset numid=3 100 >> "$LOG" 2>&1 || true
fi
# Find the PA source name for the USB mic
PA_MIC=$(pactl list sources short 2>/dev/null | grep -i 'usb.*input\|usb.*mic\|usb.*audio' | grep -v monitor | head -1 | awk '{print $2}')
if [ -n "$PA_MIC" ]; then
    MIC_DEVICE="$PA_MIC"
    # PA source volume 200% — sweet spot for Silero VAD (500% drowns in noise, 150% too quiet)
    pactl set-source-volume "$PA_MIC" 200% 2>/dev/null || true
    echo "$(date) USB mic via PulseAudio: $MIC_DEVICE (ALSA=100%, PA=200%)" >> "$LOG"
else
    MIC_DEVICE="default"
    echo "$(date) No USB mic found, using default PA source" >> "$LOG"
fi

python3 main.py --fullscreen --mic-device "$MIC_DEVICE" >> "$LOG" 2>&1

echo "$(date) KiSTI session ended" >> "$LOG"
